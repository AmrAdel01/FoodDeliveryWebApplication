{
  "info": {
    "_postman_id": "11ca9710-2f6c-4ae7-aa10-976958a214fa",
    "name": "Table & Thyme API",
    "description": "Online food ordering REST API collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"Demo1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('token', pm.response.json().data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"Demo1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('token', pm.response.json().data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Current User",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Browse Products",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products?limit=12&category=Pizza"
          }
        },
        {
          "name": "Product Details",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Product Categories",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/categories"
          }
        },
        {
          "name": "Trending Products",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/trending?limit=8"
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": { "method": "GET", "url": "{{baseUrl}}/cart" }
        },
        {
          "name": "Add Item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/cart/items"
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"quantity\": 2 }" },
            "url": "{{baseUrl}}/cart/items/{{productId}}"
          }
        },
        {
          "name": "Remove Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/items/{{productId}}"
          }
        },
        {
          "name": "Clear Cart",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/cart" }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"label\": \"Home\",\n    \"street\": \"15 Nile Street\",\n    \"city\": \"Cairo\",\n    \"phone\": \"+201001234567\",\n    \"notes\": \"Call on arrival\"\n  },\n  \"paymentMethod\": \"COD\"\n}"
            },
            "url": "{{baseUrl}}/orders"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('orderId', pm.response.json().data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "My Orders",
          "request": { "method": "GET", "url": "{{baseUrl}}/orders" }
        },
        {
          "name": "Order Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/cancel"
          }
        },
        {
          "name": "Mock Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"simulate\": \"success\" }" },
            "url": "{{baseUrl}}/orders/{{orderId}}/pay"
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/stats" }
        },
        {
          "name": "All Orders",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/orders?status=Pending"
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"status\": \"Confirmed\" }" },
            "url": "{{baseUrl}}/admin/orders/{{orderId}}/status"
          }
        },
        {
          "name": "All Products",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/products?limit=100"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Garden Pizza", "type": "text" },
                { "key": "description", "value": "Roasted vegetables, mozzarella, and basil.", "type": "text" },
                { "key": "category", "value": "Pizza", "type": "text" },
                { "key": "price", "value": "190", "type": "text" },
                { "key": "stock", "value": "20", "type": "text" },
                { "key": "isAvailable", "value": "true", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/admin/products"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"price\": 200, \"stock\": 15 }"
            },
            "url": "{{baseUrl}}/admin/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/products/{{productId}}"
          }
        }
      ]
    }
  ]
}
