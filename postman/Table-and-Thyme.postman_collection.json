{
  "info": {
    "_postman_id": "11ca9710-2f6c-4ae7-aa10-976958a214fa",
    "name": "Table & Thyme API",
    "description": "Online food ordering REST API collection.\n\nAuth: Register or Login first — both store the returned JWT into the `token` collection variable automatically, and every other request inherits Bearer auth from the collection. \"Browse Products\" stores the first result's id into `productId`, and \"Place Order\" / \"Create Product\" capture `orderId` / `productId`, so the cart, order, and admin flows chain without manual copy-paste.\n\nSet `baseUrl` if the API is not at the default address.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api/v1" },
    { "key": "token", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": {
              "raw": "http://localhost:5000/api/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "health"]
            },
            "description": "Liveness probe. Not under /api/v1 and not rate-limited."
          }
        }
      ]
    },
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Demo User\",\n  \"email\": \"demo@example.com\",\n  \"password\": \"Demo1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Password must be at least 8 characters and contain an uppercase letter, a lowercase letter, and a number."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('token', pm.response.json().data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login",
          "auth": { "type": "noauth" },
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"demo@example.com\",\n  \"password\": \"Demo1234\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Sign in. To exercise admin-only endpoints, log in with the seeded admin (ADMIN_EMAIL / ADMIN_PASSWORD from backend/.env)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('token', pm.response.json().data.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Current User",
          "request": { "method": "GET", "url": "{{baseUrl}}/auth/me" }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Browse Products",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=12&category=Pizza&search=&minPrice=&maxPrice=&sort=-createdAt",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "12", "description": "1-100" },
                { "key": "category", "value": "Pizza", "description": "Pizza | Burgers | Pasta | Drinks | Desserts" },
                { "key": "search", "value": "", "description": "Full-text keyword (alias: keyword)" },
                { "key": "minPrice", "value": "", "description": "Minimum price filter" },
                { "key": "maxPrice", "value": "", "description": "Maximum price filter" },
                { "key": "sort", "value": "-createdAt", "description": "-createdAt | createdAt | price | -price | name | -name | price_asc | price_desc" }
              ]
            },
            "description": "List available products. All query params are optional."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json().data;",
                  "if (Array.isArray(data) && data.length) pm.collectionVariables.set('productId', data[0]._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Product Details",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Product Categories",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/products/categories"
          }
        },
        {
          "name": "Trending Products",
          "auth": { "type": "noauth" },
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/products/trending?limit=8",
              "host": ["{{baseUrl}}"],
              "path": ["products", "trending"],
              "query": [{ "key": "limit", "value": "8", "description": "1-20" }]
            }
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": { "method": "GET", "url": "{{baseUrl}}/cart" }
        },
        {
          "name": "Add Item",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": \"{{productId}}\",\n  \"quantity\": 1\n}"
            },
            "url": "{{baseUrl}}/cart/items"
          }
        },
        {
          "name": "Update Item",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"quantity\": 2 }" },
            "url": "{{baseUrl}}/cart/items/{{productId}}"
          }
        },
        {
          "name": "Remove Item",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/cart/items/{{productId}}"
          }
        },
        {
          "name": "Clear Cart",
          "request": { "method": "DELETE", "url": "{{baseUrl}}/cart" }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"shippingAddress\": {\n    \"label\": \"Home\",\n    \"street\": \"15 Nile Street\",\n    \"city\": \"Cairo\",\n    \"phone\": \"+201001234567\",\n    \"notes\": \"Call on arrival\"\n  },\n  \"paymentMethod\": \"COD\"\n}"
            },
            "url": "{{baseUrl}}/orders",
            "description": "Creates an order from the current cart. paymentMethod is COD or ONLINE. street, city, and phone are required; label and notes are optional."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('orderId', pm.response.json().data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "My Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10", "description": "1-100" }
              ]
            }
          }
        },
        {
          "name": "Order Details",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        },
        {
          "name": "Cancel Order",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/orders/{{orderId}}/cancel"
          }
        },
        {
          "name": "Mock Payment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"simulate\": \"success\" }" },
            "url": "{{baseUrl}}/orders/{{orderId}}/pay",
            "description": "Mock online payment. Send \"simulate\": \"failure\" to force a failed payment (HTTP 402); any other value succeeds."
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Dashboard Stats",
          "request": { "method": "GET", "url": "{{baseUrl}}/admin/stats" }
        },
        {
          "name": "All Orders",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/orders?page=1&limit=20&status=Pending",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20", "description": "1-100" },
                { "key": "status", "value": "Pending", "description": "Pending | Confirmed | Preparing | Out for Delivery | Delivered | Cancelled" }
              ]
            }
          }
        },
        {
          "name": "Order Details (Admin)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/admin/orders/{{orderId}}",
            "description": "Fetch any order by id (admin only)."
          }
        },
        {
          "name": "Update Order Status",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{ \"status\": \"Confirmed\" }" },
            "url": "{{baseUrl}}/admin/orders/{{orderId}}/status",
            "description": "Allowed status values: Pending, Confirmed, Preparing, Out for Delivery, Delivered, Cancelled. Only forward operational transitions are accepted."
          }
        },
        {
          "name": "All Products",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/admin/products?page=1&limit=100&available=true",
              "host": ["{{baseUrl}}"],
              "path": ["admin", "products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "100", "description": "1-100" },
                { "key": "available", "value": "true", "description": "true | false — filter by availability (admin-only filter)" },
                { "key": "category", "value": "", "description": "Pizza | Burgers | Pasta | Drinks | Desserts", "disabled": true },
                { "key": "search", "value": "", "description": "Full-text keyword", "disabled": true }
              ]
            },
            "description": "Lists all products including unavailable ones."
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "Garden Pizza", "type": "text" },
                { "key": "description", "value": "Roasted vegetables, mozzarella, and basil.", "type": "text" },
                { "key": "category", "value": "Pizza", "type": "text" },
                { "key": "price", "value": "190", "type": "text" },
                { "key": "stock", "value": "20", "type": "text" },
                { "key": "isAvailable", "value": "true", "type": "text" },
                { "key": "image", "type": "file", "src": "" }
              ]
            },
            "url": "{{baseUrl}}/admin/products",
            "description": "Multipart form. An image file is required. Select a file for the `image` field before sending."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code < 300) pm.collectionVariables.set('productId', pm.response.json().data._id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{ \"price\": 200, \"stock\": 15 }"
            },
            "url": "{{baseUrl}}/admin/products/{{productId}}",
            "description": "Send JSON to update fields, or switch the body to form-data with an `image` file to replace the product image. All fields are optional."
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/admin/products/{{productId}}"
          }
        }
      ]
    }
  ]
}
